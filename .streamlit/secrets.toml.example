# Copy to Streamlit Cloud → Settings → Secrets (TOML format)

GROQ_API_KEY = "gsk_your_key_here"
LLM_ENABLED = "true"
LLM_MODEL = "llama-3.3-70b-versatile"
DATABASE_URL = "sqlite:///./data/processed/restaurants.db"
CORS_ORIGINS = "http://localhost:5173,https://restaurant-recommendation-app-seven.vercel.app"

# IMPORTANT: In Streamlit Cloud → Settings → Sharing, set the app to
# "Anyone with the link can view". Private apps block API calls from Vercel.
