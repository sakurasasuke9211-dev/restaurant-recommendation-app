# Database
DATABASE_URL=sqlite:///./data/processed/restaurants.db

# API
CORS_ORIGINS=http://localhost:5173
MAX_RECOMMENDATIONS=5

# Run API (local): uvicorn src.phase2.main:app --reload --port 8000
# Run API + Streamlit (production-like): streamlit run streamlit_app.py
# Run UI:   cd frontend && npm install && npm run dev
# Run ingestion: python scripts/ingest.py
# Streamlit Cloud secrets: see .streamlit/secrets.toml.example

# LLM — Groq (Phase 3)
# Copy this file to .env and set your Groq API key
GROQ_API_KEY=gsk_your_key_here
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile
LLM_ENABLED=true
LLM_TIMEOUT_SECONDS=30
